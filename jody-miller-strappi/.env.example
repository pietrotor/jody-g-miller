# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=1337

# URL where the frontend runs (used for CORS)
# Local:      http://localhost:3000
# Production: https://jodymiller.com
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Strapi Security Keys
# Generate each with: openssl rand -base64 32
# ─────────────────────────────────────────────
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
ENCRYPTION_KEY=
JWT_SECRET=

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# Local: matches docker-compose.yml defaults
# Production: DigitalOcean Managed DB or VPS values
# ─────────────────────────────────────────────
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=jody_miller_cms
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=
DATABASE_SSL=false

# Optional: full connection string (overrides individual fields above)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
