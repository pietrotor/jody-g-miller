{
  "kind": "collectionType",
  "collectionName": "archive_items",
  "info": {
    "singularName": "archive-item",
    "pluralName": "archive-items",
    "displayName": "Archive Item",
    "description": "Articles, videos, and podcasts in Jody's archive"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": ["article", "video", "podcast"],
      "required": true
    },
    "year": {
      "type": "integer",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "source": {
      "type": "string"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "externalUrl": {
      "type": "string"
    },
    "youtubeId": {
      "type": "string"
    },
    "embedUrl": {
      "type": "string"
    },
    "duration": {
      "type": "string"
    },
    "pdf": {
      "allowedTypes": ["files"],
      "type": "media",
      "multiple": false
    },
    "coverImage": {
      "allowedTypes": ["images"],
      "type": "media",
      "multiple": false
    },
    "publishedDate": {
      "type": "date",
      "required": true
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "archiveItems"
    }
  }
}
